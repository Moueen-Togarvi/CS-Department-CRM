# Database connection URL - Neon PostgreSQL (pooled - for Prisma Client)
DATABASE_URL="postgresql://user:password@ep-host-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Direct (non-pooled) connection for migrations
DIRECT_URL="postgresql://user:password@ep-host.us-east-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth secret key (random string used for encrypting JWTs/cookies)
# For local dev, a fallback is in src/lib/auth.ts, but in production this MUST be defined.
# You can generate a strong key by running: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-key-here"

# NextAuth canonical URL (the base URL of the site)
NEXTAUTH_URL="https://cs-department-crm.vercel.app"
