generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  FACULTY
  STUDENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum CourseType {
  THEORY
  LAB
  PROJECT
  SEMINAR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum GradeScale {
  A
  A_MINUS
  B_PLUS
  B
  B_MINUS
  C_PLUS
  C
  C_MINUS
  D_PLUS
  D
  F
  I
  W
}

enum ProjectStatus {
  PROPOSED
  APPROVED
  IN_PROGRESS
  SUBMITTED
  EVALUATED
  DEFENDED
  PASSED
  FAILED
}

enum AnnouncementType {
  NOTICE
  EVENT
  SEMINAR
  URGENT
  GENERAL
}

enum DocumentCategory {
  SYLLABUS
  NOTES
  ASSIGNMENT
  PAPER
  REFERENCE
  OTHER
}

enum EvaluationType {
  PROPOSAL
  MID
  FINAL
  SUPERVISOR
  EXTERNAL
}

enum SemesterType {
  FALL
  SPRING
  SUMMER
}

enum SessionStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  ARCHIVED
}

// ==================== MODELS ====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(STUDENT)
  avatar    String?
  phone     String?
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student     Student?
  faculty     Faculty?
  attendanceMarked Attendance[]  @relation("AttendanceMarker")
  announcementsCreated Announcement[] @relation("AnnouncementAuthor")
  documentsUploaded   Document[] @relation("DocumentUploader")

  @@index([email])
  @@index([role])
}

model Department {
  id              String   @id @default(cuid())
  name            String   @unique
  code            String   @unique
  description     String?
  headId          String?   @unique
  establishedYear Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  head      Faculty?  @relation("DeptHead", fields: [headId], references: [id])
  faculty       Faculty[]
  courses       Course[]
  students      Student[]
  announcements Announcement[]
}

model Semester {
  id        String       @id @default(cuid())
  name      String
  type      SemesterType
  year      Int
  startDate DateTime
  endDate   DateTime
  status    SessionStatus @default(UPCOMING)
  isCurrent Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  enrollments Enrollment[]
  timetables  Timetable[]
  attendance  Attendance[]
  results     Result[]
  projects    Project[]
  documents   Document[]

  @@unique([type, year])
  @@index([isCurrent])
}

model Room {
  id          String  @id @default(cuid())
  name        String
  building    String
  floor       Int?
  capacity    Int     @default(30)
  roomType    String  @default("CLASSROOM")
  hasProjector Boolean @default(false)
  hasAC       Boolean @default(false)
  isAvailable Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  timetables Timetable[]
}

model Student {
  id               String   @id @default(cuid())
  userId           String   @unique
  studentId        String   @unique
  departmentId     String
  currentSemester  Int      @default(1)
  enrollmentYear   Int
  batch            String?
  program          String   @default("BS")
  status           String   @default("ACTIVE")
  gpa              Float?
  totalCredits     Int      @default(0)
  dateOfBirth      DateTime?
  gender           Gender?
  address          String?
  guardianName     String?
  guardianPhone    String?
  emergencyContact String?
  profilePicture   String?
  fatherName       String?
  cnic             String?
  mobileNumber     String?
  fatherPhone      String?
  session          String?
  section          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  department  Department  @relation(fields: [departmentId], references: [id])
  enrollments Enrollment[]
  attendance  Attendance[]
  results     Result[]
  projects    ProjectMember[]

  @@index([departmentId])
  @@index([batch])
  @@index([studentId])
}

model Faculty {
  id                  String   @id @default(cuid())
  userId              String   @unique
  facultyId           String   @unique
  departmentId        String
  designation         String
  specialization      String?
  highestDegree       String?
  joiningDate         DateTime?
  officeRoom          String?
  officeHours         String?
  maxCoursesPerSemester Int  @default(3)
  isAvailable         Boolean  @default(true)
  bio                 String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  department      Department    @relation(fields: [departmentId], references: [id])
  headOfDepartment Department?  @relation("DeptHead")
  courses         Course[]      @relation("FacultyCourses")
  timetables      Timetable[]
  attendance      Attendance[]
  supervisedProjects Project[]  @relation("Supervisor")
  coSupervisedProjects Project[] @relation("CoSupervisor")
  fypEvaluations  FYPEvaluation[]

  @@index([departmentId])
  @@index([facultyId])
}

model Course {
  id               String     @id @default(cuid())
  code             String     @unique
  name             String
  departmentId     String
  creditHours      Int        @default(3)
  labCreditHours   Int        @default(0)
  courseType       CourseType @default(THEORY)
  semesterOffered  Int?
  prerequisiteIds  String     @default("[]")
  description      String?
  outline          String?
  syllabus         String?
  objectives       String?
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  department  Department  @relation(fields: [departmentId], references: [id])
  instructorId String?
  instructor  Faculty?    @relation("FacultyCourses", fields: [instructorId], references: [id])
  enrollments Enrollment[]
  timetables  Timetable[]
  attendance  Attendance[]
  results     Result[]
  documents   Document[]

  @@index([departmentId])
  @@index([instructorId])
  @@index([semesterOffered])
}

model Enrollment {
  id            String   @id @default(cuid())
  studentId     String
  courseId      String
  semesterId    String
  section       String   @default("A")
  enrollmentDate DateTime @default(now())
  status        String   @default("ENROLLED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student     Student  @relation(fields: [studentId], references: [id])
  course      Course   @relation(fields: [courseId], references: [id])
  semester    Semester @relation(fields: [semesterId], references: [id])
  result      Result?

  @@unique([studentId, courseId, semesterId])
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String?
  facultyId String?
  courseId  String
  semesterId String
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  remarks   String?
  markedBy  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  student    Student?  @relation(fields: [studentId], references: [id])
  faculty    Faculty?  @relation(fields: [facultyId], references: [id])
  course     Course    @relation(fields: [courseId], references: [id])
  semester   Semester  @relation(fields: [semesterId], references: [id])
  markedByUser User     @relation("AttendanceMarker", fields: [markedBy], references: [id])

  @@unique([studentId, courseId, semesterId, date])
  @@index([courseId, date])
  @@index([semesterId])
}

model Result {
  id               String     @id @default(cuid())
  enrollmentId     String     @unique
  studentId        String
  courseId         String
  semesterId       String
  assignmentMarks  Float?
  quizMarks        Float?
  midtermMarks     Float?
  finalMarks       Float?
  labMarks         Float?
  projectMarks     Float?
  totalMarks       Float?
  percentage       Float?
  grade            GradeScale?
  gradePoint       Float?
  isLocked         Boolean    @default(false)
  remarks          String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])
  course     Course     @relation(fields: [courseId], references: [id])
  semester   Semester   @relation(fields: [semesterId], references: [id])

  @@index([studentId, semesterId])
  @@index([courseId, semesterId])
  @@index([grade])
}

model Timetable {
  id            String    @id @default(cuid())
  courseId      String
  facultyId     String
  semesterId    String
  roomId        String
  section       String    @default("A")
  day           DayOfWeek
  startTime     String
  endTime       String
  slotType      String    @default("THEORY")
  isRecurring   Boolean   @default(true)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  course   Course   @relation(fields: [courseId], references: [id])
  faculty  Faculty  @relation(fields: [facultyId], references: [id])
  semester Semester @relation(fields: [semesterId], references: [id])
  room     Room     @relation(fields: [roomId], references: [id])

  @@index([facultyId, day, startTime])
  @@index([roomId, day, startTime])
  @@index([semesterId])
  @@index([courseId, semesterId])
}

model Announcement {
  id             String           @id @default(cuid())
  title          String
  content        String
  type           AnnouncementType @default(GENERAL)
  priority       Int              @default(0)
  targetAudience String           @default("ALL")
  departmentId   String?
  eventDate      DateTime?
  eventLocation  String?
  attachmentUrl  String?
  isPublished    Boolean          @default(true)
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdBy      String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  department       Department? @relation(fields: [departmentId], references: [id])
  createdByUser    User        @relation("AnnouncementAuthor", fields: [createdBy], references: [id])

  @@index([type])
  @@index([isPublished, publishedAt])
  @@index([priority])
  @@index([targetAudience])
}

model Project {
  id              String        @id @default(cuid())
  title           String
  description     String
  semesterId      String
  supervisorId    String
  coSupervisorId  String?
  status          ProjectStatus @default(PROPOSED)
  domain          String?
  methodology     String?
  proposalUrl     String?
  finalReportUrl  String?
  presentationDate DateTime?
  defenseDate     DateTime?
  finalGrade      GradeScale?
  finalGradePoint Float?
  remarks         String?
  proposedAt      DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  semester  Semester          @relation(fields: [semesterId], references: [id])
  supervisor Faculty           @relation("Supervisor", fields: [supervisorId], references: [id])
  coSupervisor Faculty?         @relation("CoSupervisor", fields: [coSupervisorId], references: [id])
  members    ProjectMember[]
  evaluations FYPEvaluation[]
  milestones  ProjectMilestone[]

  @@index([semesterId])
  @@index([supervisorId])
  @@index([status])
}

model ProjectMember {
  id                String  @id @default(cuid())
  projectId         String
  studentId         String
  role              String  @default("MEMBER")
  contributionPercent Int?
  createdAt         DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id])

  @@unique([projectId, studentId])
  @@index([studentId])
}

model ProjectMilestone {
  id           String   @id @default(cuid())
  projectId    String
  title        String
  description  String?
  dueDate      DateTime
  completedDate DateTime?
  status       String   @default("PENDING")
  feedback     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([dueDate])
}

model FYPEvaluation {
  id              String         @id @default(cuid())
  projectId       String
  evaluatorId     String
  evaluationType  EvaluationType
  criteriaScores  String
  totalScore      Float?
  maxTotalScore   Float?         @default(100)
  comments        String?
  evaluatedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evaluator Faculty @relation(fields: [evaluatorId], references: [id])

  @@unique([projectId, evaluationType])
  @@index([evaluatorId])
}

model Document {
  id           String           @id @default(cuid())
  title        String
  description  String?
  category     DocumentCategory @default(OTHER)
  courseId     String?
  semesterId   String?
  uploadedBy   String
  fileUrl      String
  fileType     String?
  fileSize     Int?
  downloadCount Int             @default(0)
  isPublic     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  course          Course?  @relation(fields: [courseId], references: [id])
  semester        Semester? @relation(fields: [semesterId], references: [id])
  uploadedByUser  User     @relation("DocumentUploader", fields: [uploadedBy], references: [id])

  @@index([courseId])
  @@index([category])
  @@index([uploadedBy])
}